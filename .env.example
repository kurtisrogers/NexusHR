# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,.localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=hrms.settings.development

# Multi-tenant subdomains
TENANT_BASE_DOMAIN=localhost
TENANT_URL_SCHEME=http
TENANT_PORT=8000

# Database (production)
DB_NAME=nexushr
DB_USER=nexushr
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Stripe (optional — dev mode activates subscriptions without Stripe)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Billing
BILLING_TRIAL_DAYS=14

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=NexusHR <noreply@nexushr.local>
